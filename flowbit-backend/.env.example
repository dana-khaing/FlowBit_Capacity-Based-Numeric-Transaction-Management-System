SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Option A: full database URL
# Supabase database URLs are PostgreSQL URLs, so Django can use them directly.
# DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres

# Option B: discrete database fields
DB_ENGINE=django.db.backends.postgresql
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=db.example.supabase.co
DB_PORT=5432

# Supabase commonly requires SSL.
DB_SSLMODE=require
DB_CONNECT_TIMEOUT=10
DB_CONN_MAX_AGE=600
DB_DISABLE_SERVER_SIDE_CURSORS=False

GOOGLE_OAUTH_CLIENT_ID=
DEFAULT_FROM_EMAIL=noreply@flowbit.local
FRONTEND_PASSWORD_RESET_URL=
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=2
